---
import Layout from '../../layouts/Layout.astro';
import { GAS_URL } from '../../consts';

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---

<Layout
  title="予約完了｜Fortune Lab☆！"
  description="鑑定予約の完了ページです。"
>
  <section class="section">
    <div class="container narrow">
      <div id="complete-card" class="complete-card">
        <div class="spinner" id="spinner" aria-hidden="true"></div>
        <h1 id="c-title" class="c-title">お支払いを確認しています…</h1>
        <p id="c-desc" class="c-desc">しばらくお待ちください。</p>
        <div id="c-summary" class="c-summary" hidden></div>
        <div id="c-actions" class="c-actions" hidden>
          <a class="btn btn-primary" href={link('/')}>トップへ戻る</a>
          <a class="btn btn-ghost" href={link('/tellers')}>占い師を見る</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ GAS_URL }}>
  const spinner = document.getElementById('spinner');
  const titleEl = document.getElementById('c-title');
  const descEl = document.getElementById('c-desc');
  const summaryEl = document.getElementById('c-summary');
  const actionsEl = document.getElementById('c-actions');
  const card = document.getElementById('complete-card');

  function done(state) {
    spinner.style.display = 'none';
    actionsEl.hidden = false;
    card.classList.add(state);
  }

  (async function confirm() {
    const params = new URLSearchParams(window.location.search);
    const sessionId = params.get('session_id');

    if (!sessionId) {
      titleEl.textContent = 'ページを開けませんでした';
      descEl.textContent = '決済情報が見つかりません。お手数ですが、予約フォームからやり直してください。';
      done('error');
      return;
    }

    try {
      const url = GAS_URL + '?action=confirm&session_id=' + encodeURIComponent(sessionId);
      const res = await fetch(url);
      const data = await res.json();

      if (data.status === 'confirmed') {
        titleEl.textContent = 'ご予約が完了しました';
        descEl.textContent = 'お支払いを確認しました。担当より日程確定のご連絡をいたします。';
        const s = data.summary || {};
        const rows = [
          s.tellerName ? ['占い師', s.tellerName] : null,
          s.menu ? ['メニュー', s.menu] : null,
          s.date && s.time ? ['日時', s.date + ' ' + s.time] : null,
          s.amount ? ['お支払い', '¥' + Number(s.amount).toLocaleString()] : null,
        ].filter(Boolean);
        if (rows.length) {
          summaryEl.innerHTML = rows
            .map((r) => `<div class="row"><span>${r[0]}</span><strong>${r[1]}</strong></div>`)
            .join('');
          summaryEl.hidden = false;
        }
        done('success');
      } else if (data.status === 'pending') {
        titleEl.textContent = 'お支払いが確認できませんでした';
        descEl.textContent = 'まだ入金が確認できていません。お支払いが完了している場合は、少し時間をおいて再読み込みしてください。';
        done('error');
      } else {
        titleEl.textContent = '確認に失敗しました';
        descEl.textContent = data.message || 'お手数ですが、公式LINEよりお問い合わせください。';
        done('error');
      }
    } catch (e) {
      titleEl.textContent = '通信エラー';
      descEl.textContent = 'ネットワークをご確認のうえ、ページを再読み込みしてください。';
      done('error');
    }
  })();
</script>

<style>
  .narrow {
    max-width: 560px;
  }
  .complete-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    box-shadow: var(--shadow);
  }
  .complete-card.success {
    border-color: var(--color-primary);
  }
  .complete-card.error {
    border-color: #e0b4b4;
  }
  .c-title {
    font-size: clamp(1.4rem, 4vw, 1.9rem);
    margin-bottom: 0.8rem;
  }
  .complete-card.success .c-title {
    color: var(--color-primary-soft);
  }
  .c-desc {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .c-summary {
    display: grid;
    gap: 0.5rem;
    text-align: left;
    max-width: 340px;
    margin: 0 auto 1.8rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1rem 1.2rem;
  }
  .c-summary .row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.92rem;
  }
  .c-summary .row span {
    color: var(--color-text-muted);
  }
  .c-actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .spinner {
    width: 38px;
    height: 38px;
    margin: 0 auto 1.5rem;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
