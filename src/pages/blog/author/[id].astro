---
import Layout from '../../../layouts/Layout.astro';
import { getTellers, getPosts } from '../../../lib/notion';

export async function getStaticPaths() {
  const tellers = await getTellers();
  return tellers.map((t) => ({ params: { id: t.id }, props: { teller: t } }));
}

const { teller } = Astro.props;
const { id } = Astro.params;

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const fmtDate = (d: Date) =>
  `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;

const posts = (await getPosts()).filter((p) => p.authorId === id);
---

<Layout
  title={`${teller.name}の記事｜Fortune Lab`}
  description={`${teller.name} が綴るブログ記事の一覧です。`}
>
  <section class="section">
    <div class="container">
      <a class="back" href={link('/blog')}>← ブログ一覧へ</a>

      <header class="author-head">
        {
          teller.image ? (
            <img src={teller.image} alt={`${teller.name}の写真`} />
          ) : (
            <span class="author-noimg">☾</span>
          )
        }
        <div>
          <h1 class="author-name">{teller.name}</h1>
          {teller.kana && <p class="author-kana">{teller.kana}</p>}
          {teller.role && <p class="author-role">{teller.role}</p>}
          <a class="author-link" href={link(`/tellers/${teller.id}`)}>
            プロフィール・鑑定予約へ →
          </a>
        </div>
      </header>

      {
        posts.length === 0 ? (
          <p class="empty">まだ記事がありません。</p>
        ) : (
          <ul class="post-list">
            {posts.map((post) => (
              <li class="post-card">
                <a class="post-link" href={link(`/blog/${post.slug}`)}>
                  <span class="post-date">{fmtDate(post.publishDate)}</span>
                  <h2 class="post-title">{post.title}</h2>
                  {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .back {
    display: inline-block;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .author-head {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    max-width: 760px;
    margin: 0 auto 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .author-head img,
  .author-noimg {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--color-border);
    flex: 0 0 auto;
  }
  .author-noimg {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(160deg, var(--color-night), var(--color-night-2));
    color: var(--color-accent);
    font-size: 2rem;
  }
  .author-name {
    font-size: 1.5rem;
  }
  .author-kana {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .author-role {
    color: var(--color-primary-soft);
    font-size: 0.95rem;
  }
  .author-link {
    display: inline-block;
    margin-top: 0.3rem;
    font-size: 0.88rem;
    color: var(--color-accent-soft);
    font-weight: 600;
  }
  .empty {
    text-align: center;
    color: var(--color-text-muted);
  }
  .post-list {
    list-style: none;
    display: grid;
    gap: 1.25rem;
    max-width: 760px;
    margin-inline: auto;
  }
  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: transform 0.15s ease, box-shadow 0.2s ease;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }
  .post-link {
    display: block;
    padding: 1.4rem 1.6rem;
    color: inherit;
  }
  .post-date {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }
  .post-title {
    font-size: 1.2rem;
    margin: 0.35rem 0 0.5rem;
  }
  .post-excerpt {
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }
</style>
