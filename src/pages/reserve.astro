---
import Layout from '../layouts/Layout.astro';
import { GAS_URL, LIFF_ID, LINE_URL, MENU_TYPES } from '../consts';
import { getTellers } from '../lib/notion';

const tellers = await getTellers();

// 予約可能な時間枠（10:00〜21:30 / 30分刻み）
const timeSlots: string[] = [];
for (let h = 10; h <= 21; h++) {
  for (const m of ['00', '30']) {
    timeSlots.push(`${String(h).padStart(2, '0')}:${m}`);
  }
}
---

<Layout
  title="鑑定予約｜Fortune Lab"
  description="Fortune Lab の鑑定予約フォームです。占い師・鑑定メニュー・日時を選んでお申し込みください。"
>
  <section class="section">
    <div class="container narrow">
      <h1 class="page-title">鑑定のご予約</h1>
      <p class="page-lead">
        ご希望の占い師・鑑定メニュー・日時を選んで送信してください。<br />
        折り返し、担当より日程確定のご連絡をいたします。
      </p>

      {
        !GAS_URL && (
          <p class="setup-note">
            ⚠️ 予約フォームの送信先（GAS_URL）が未設定です。<br />
            <code>src/consts.ts</code> の <code>GAS_URL</code> を設定すると送信が有効になります。
          </p>
        )
      }

      <form id="reserve-form" class="reserve-form">
        <p id="liff-status" class="liff-status" hidden></p>

        <div class="field" id="name-field">
          <label for="userName">お名前<span class="req">必須</span></label>
          <input type="text" id="userName" name="userName" placeholder="お名前を入力"
            autocomplete="name" required />
        </div>

        <div class="field">
          <label for="email">メールアドレス<span class="req">必須</span></label>
          <input type="email" id="email" name="email" placeholder="example@email.com"
            autocomplete="email" required />
        </div>

        <div class="field">
          <label for="phone">電話番号<span class="opt">任意</span></label>
          <input type="tel" id="phone" name="phone" placeholder="090-1234-5678"
            autocomplete="tel" />
        </div>

        <div class="field">
          <label for="teller">ご希望の占い師<span class="opt">任意</span></label>
          <select id="teller" name="teller">
            <option value="">指定なし（おまかせ）</option>
            {tellers.map((t) => (
              <option value={t.pageId} data-id={t.id} data-name={t.name}>
                {t.name}{t.role ? `（${t.role}）` : ''}
              </option>
            ))}
          </select>
        </div>

        <div class="field">
          <label for="menu">鑑定メニュー<span class="req">必須</span></label>
          <select id="menu" name="menu" required>
            <option value="" disabled selected>メニューを選択</option>
            {MENU_TYPES.map((m) => <option value={m}>{m}</option>)}
          </select>
        </div>

        <div class="field">
          <label for="date">ご希望日<span class="req">必須</span></label>
          <input type="date" id="date" name="date" required />
        </div>

        <div class="field">
          <label for="time">ご希望時間<span class="req">必須</span></label>
          <select id="time" name="time" required>
            <option value="" disabled selected>時間を選択</option>
            {timeSlots.map((t) => <option value={t}>{t}</option>)}
          </select>
        </div>

        <div class="field">
          <label for="note">ご相談内容・ご要望<span class="opt">任意</span></label>
          <textarea id="note" name="note" rows="3"
            placeholder="鑑定でお聞きになりたいことなど"></textarea>
        </div>

        <button type="submit" id="submit-btn" class="btn btn-primary submit-btn">
          この内容で予約する
        </button>

        <p id="result" class="result" role="status" aria-live="polite"></p>
      </form>

      {
        LINE_URL && (
          <p class="fallback-note">
            うまく送信できない場合は、
            <a href={LINE_URL} target="_blank" rel="noopener noreferrer">公式LINE</a>
            から直接ご連絡ください。
          </p>
        )
      }
    </div>
  </section>
</Layout>

<!-- LIFF SDK -->
<script src="https://static.line-scdn.net/liff/edge/2/sdk.js" is:inline></script>

<script define:vars={{ GAS_URL, LIFF_ID }}>
  const form = document.getElementById('reserve-form');
  const nameInput = document.getElementById('userName');
  const nameField = document.getElementById('name-field');
  const dateInput = document.getElementById('date');
  const tellerSelect = document.getElementById('teller');
  const submitBtn = document.getElementById('submit-btn');
  const resultEl = document.getElementById('result');
  const liffStatus = document.getElementById('liff-status');

  let lineUserId = '';

  // 予約日の下限を「今日」に設定
  (function setMinDate() {
    const now = new Date();
    const yyyy = now.getFullYear();
    const mm = String(now.getMonth() + 1).padStart(2, '0');
    const dd = String(now.getDate()).padStart(2, '0');
    dateInput.min = `${yyyy}-${mm}-${dd}`;
  })();

  // URL の ?teller=<id> で占い師を初期選択
  (function preselectTeller() {
    const params = new URLSearchParams(window.location.search);
    const wanted = params.get('teller');
    if (!wanted) return;
    for (const opt of tellerSelect.options) {
      if (opt.getAttribute('data-id') === wanted) {
        tellerSelect.value = opt.value;
        break;
      }
    }
  })();

  function showResult(message, type) {
    resultEl.textContent = message;
    resultEl.className = 'result ' + (type || '');
  }

  // LIFF 初期化（LIFF_ID 未設定なら Web予約モード）
  async function initLiff() {
    if (!LIFF_ID || typeof liff === 'undefined') return;
    try {
      await liff.init({ liffId: LIFF_ID });
      if (!liff.isLoggedIn()) {
        liff.login();
        return;
      }
      const profile = await liff.getProfile();
      lineUserId = profile.userId;
      nameInput.value = profile.displayName;
      nameInput.readOnly = true;
      nameField.classList.add('locked');
      liffStatus.hidden = false;
      liffStatus.textContent = `${profile.displayName} さんとして予約します`;
    } catch (e) {
      console.error('LIFF init error:', e);
    }
  }
  initLiff();

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    showResult('', '');

    if (!GAS_URL) {
      showResult('現在オンライン予約は準備中です。恐れ入りますが、しばらくお待ちください。', 'error');
      return;
    }

    const userName = nameInput.value.trim();
    const email = document.getElementById('email').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const menu = document.getElementById('menu').value;
    const date = dateInput.value;
    const time = document.getElementById('time').value;
    const note = document.getElementById('note').value.trim();

    const tellerOpt = tellerSelect.options[tellerSelect.selectedIndex];
    const tellerPageId = tellerSelect.value; // Notion 占い師DB のページID（リレーション用）
    const tellerName = tellerOpt ? (tellerOpt.getAttribute('data-name') || '') : '';

    if (!userName || !email || !menu || !date || !time) {
      showResult('必須項目をすべて入力してください。', 'error');
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showResult('メールアドレスの形式が正しくありません。', 'error');
      return;
    }

    const userId = lineUserId || 'web-' + Date.now();

    submitBtn.disabled = true;
    submitBtn.textContent = '送信中…';

    try {
      // CORSプリフライト回避のため text/plain で送信（GAS側でJSON.parse）
      const res = await fetch(GAS_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify({
          userName, userId, email, phone,
          tellerPageId, tellerName,
          menu, date, time, note,
        }),
      });
      const result = await res.json();

      if (result.status === 'success') {
        showResult(`ご予約を受け付けました。（${menu} / ${date} ${time}）折り返しご連絡いたします。`, 'success');
        form.reset();
        if (typeof liff !== 'undefined' && LIFF_ID && liff.isInClient && liff.isInClient()) {
          try {
            await liff.sendMessages([
              { type: 'text', text: `予約しました：${menu} / ${date} ${time}` },
            ]);
          } catch (_) {}
          setTimeout(() => liff.closeWindow(), 1200);
        }
      } else {
        showResult('エラー: ' + (result.message || '送信に失敗しました。'), 'error');
      }
    } catch (e) {
      console.error(e);
      showResult('送信に失敗しました。通信環境をご確認ください。', 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'この内容で予約する';
    }
  });
</script>

<style>
  .narrow {
    max-width: 580px;
  }
  .page-title {
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    margin-bottom: 1rem;
  }
  .page-lead {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .setup-note {
    background: #fff7e6;
    border: 1px solid #f0d999;
    color: #8a6d1a;
    border-radius: 10px;
    padding: 0.9rem 1.1rem;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .setup-note code {
    background: rgba(0, 0, 0, 0.06);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    font-size: 0.85em;
  }
  .reserve-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    display: grid;
    gap: 1.3rem;
    box-shadow: var(--shadow);
  }
  .liff-status {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.6rem 0.9rem;
    font-size: 0.9rem;
    color: var(--color-primary-soft);
    margin: 0;
  }
  .field {
    display: grid;
    gap: 0.45rem;
  }
  .field label {
    font-weight: 600;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .req {
    font-size: 0.68rem;
    font-weight: 700;
    color: #fff;
    background: var(--color-primary);
    border-radius: 4px;
    padding: 0.05rem 0.4rem;
  }
  .opt {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--color-text-muted);
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.05rem 0.4rem;
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 1rem;
    font-family: inherit;
  }
  .field textarea {
    resize: vertical;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(124, 92, 191, 0.18);
  }
  .field.locked input {
    background: var(--color-bg-soft);
    color: var(--color-text-muted);
  }
  .submit-btn {
    width: 100%;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-family: inherit;
    margin-top: 0.3rem;
  }
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .result {
    margin: 0;
    text-align: center;
    font-size: 0.92rem;
    min-height: 1.2em;
  }
  .result.success {
    color: var(--color-primary-soft);
    font-weight: 700;
  }
  .result.error {
    color: #d9534f;
  }
  .fallback-note {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    margin-top: 1.5rem;
  }
</style>
