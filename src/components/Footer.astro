---
import { LINE_URL, SITE_NAME, SITE_TAGLINE, SISTER_SITE_URL, SISTER_SITE_NAME, SISTER_SITE_DESC } from '../consts';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---

<footer class="site-footer night">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand-mark">☾</span> {SITE_NAME}
      <p class="footer-tagline">{SITE_TAGLINE}</p>
    </div>
    <nav class="footer-nav">
      <a href={link('/')}>ホーム</a>
      <a href={link('/tellers')}>占い師</a>
      <a href={link('/blog')}>ブログ</a>
      <a href={link('/reserve')}>予約</a>
      {LINE_URL && (
        <a href={LINE_URL} target="_blank" rel="noopener noreferrer">LINEで相談</a>
      )}
      <a
        class="footer-sister"
        href={SISTER_SITE_URL}
        target="_blank"
        rel="noopener noreferrer"
      >姉妹サイト｜{SISTER_SITE_DESC} {SISTER_SITE_NAME} ↗</a>
    </nav>
  </div>
  <div class="container footer-bottom">
    <small>&copy; {year} {SITE_NAME}. All rights reserved.</small>
  </div>
</footer>

<style>
  .site-footer {
    padding-block: 3rem 1.5rem;
    margin-top: 0;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }
  .footer-brand {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-night-text);
  }
  .brand-mark {
    color: var(--color-accent);
  }
  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-night-muted);
    margin-top: 0.4rem;
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9rem;
  }
  .footer-nav a {
    color: var(--color-night-muted);
  }
  .footer-nav a:hover {
    color: var(--color-accent);
  }
  .footer-sister {
    margin-top: 0.4rem;
    color: var(--color-accent) !important;
    font-weight: 600;
  }
  .footer-sister:hover {
    color: var(--color-night-text) !important;
  }
  .footer-bottom {
    margin-top: 2rem;
    text-align: center;
    color: var(--color-night-muted);
    position: relative;
    z-index: 1;
  }
</style>
