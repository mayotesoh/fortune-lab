---
import { LINE_URL, LINE_LABEL } from '../consts';

interface Props {
  label?: string;
}
const { label = LINE_LABEL } = Astro.props;
---

{
  LINE_URL && (
    <a class="btn btn-line" href={LINE_URL} target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 3C6.48 3 2 6.6 2 11.02c0 2.55 1.5 4.8 3.86 6.25-.17.6-.62 2.2-.71 2.54-.11.42.16.41.33.3.14-.09 2.16-1.43 3.04-2.02.78.11 1.59.17 2.48.17 5.52 0 10-3.6 10-8.04C21 6.6 17.52 3 12 3z" />
      </svg>
      <span>{label}</span>
    </a>
  )
}
